# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_USE_CLI_AUTH=false
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Fallback: Standard OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Assessment settings
MAX_PROBE_TIMEOUT=120          # seconds per probe
REQUEST_TIMEOUT=15             # seconds per HTTP request
NMAP_TIMEOUT=180               # seconds for nmap scan
MAX_REDIRECTS=10
RATE_LIMIT_DELAY=0.5           # seconds between HTTP requests

# Scan scope
VERIFY_TLS=true                # Set false only for self-signed cert targets
NMAP_PORTS=21,22,23,25,53,80,110,111,135,139,143,443,445,993,995,1723,3306,3389,5900,8080,8443,8000,9000,9090,9443
